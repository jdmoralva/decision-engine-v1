# Función para detectar patrón "W" (doble suelo)
detectWPattern <- function(prices, min_diff = 0.02, min_rebound = 0.05) {
# 'min_diff' define la diferencia mínima entre los dos mínimos
# 'min_rebound' define la subida mínima desde el segundo mínimo para considerar un patrón válido
pattern_signal <- rep(0, length(prices))
for (i in 3:(length(prices) - 1)) {
if (prices[i-2] > prices[i-1] && prices[i-1] < prices[i] &&
prices[i] > prices[i-1] && prices[i] < prices[i+1] &&
(prices[i-1] - min(prices[i-2], prices[i]))/prices[i-1] > min_diff &&
(prices[i+1] - prices[i])/prices[i] > min_rebound) {
pattern_signal[i] <- 1  # Señal de patrón "W" detectada
}
}
return(pattern_signal)
}
# Aplicar la función a los precios de cierre de AAPL
W_signal <- detectWPattern(Cl(AAPL))
